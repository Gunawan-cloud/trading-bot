# GateIO API Credentials
GATEIO_API_KEY=your_api_key_here
GATEIO_API_SECRET=your_api_secret_here
GATEIO_UID=your_uid_here

# Trading Symbols (comma-separated)
TRADING_SYMBOLS=BTC_USDT,ETH_USDT,SOL_USDT

# Risk Management
RISK_PER_TRADE=2.0
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=500
MAX_OPEN_POSITIONS=5

# Strategy Parameters
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20

# Trading Mode
MODE=backtest  # backtest or live
LEVERAGE=10
POSITION_TYPE=long  # long, short, or both

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# Notifications
ENABLE_TELEGRAM=false
TELEGRAM_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
